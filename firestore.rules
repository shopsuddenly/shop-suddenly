rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // User can read/write their own data
      allow read, write: if isOwner(userId);
      // Admin has full access (for replacement orders, etc.)
      allow read, write: if isAdmin();


      // Addresses Subcollection
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }
      
      // Wishlist Subcollection
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId);
      }

      // Coupon Usage Subcollection
      match /coupon_usage/{usageId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Carts collection
    // Path: /carts/{userId}/items/{itemId}
    match /carts/{userId} {
      allow read, write: if isOwner(userId);

      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Products collection
    match /products/{productId} {
      // Public read access
      allow read: if true;
      // Admin has full access
      allow create, delete: if isAdmin();
      // Admin or User (for stock updates) can update
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'variants', 'averageRating', 'reviewCount']));
    }
    
    // Categories collection
    match /categories/{categoryId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      // Admins have full access (check first)
      allow read, write: if isAdmin();
      
      // Single document read - verify ownership
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Query/list operations - allow authenticated users (query filters by userId)
      allow list: if isAuthenticated();
      
      // Users can create orders for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own orders (for cancellation, return requests, etc.)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users cannot delete orders
      allow delete: if false;
    }
    // Content (CMS) collection
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings collection (GST config, etc.)
    match /settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Pages (CMS) collection
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Contact Messages
    match /messages/{messageId} {
      allow create: if true; // Public can create
      allow read, update, delete: if isAdmin(); // Only admin can read
    }

    // OTP Requests collection
    // Used for unauthenticated signup verification
    match /otp_requests/{email} {
      // Allow creation by anyone (signup)
      // Ideally should rate-limit, but validation is minimal here
      // Allow create/update by anyone (signup retries)
      allow write: if request.resource.data.keys().hasAll(['email', 'otp', 'createdAt', 'expiresAt', 'verified']);
      
      // Allow read/delete by anyone (needed for verification API which uses client SDK)
      // In production, use Admin SDK to bypass this, but for now this is the workaround
      allow read, delete: if true;
    }
    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // Coupons collection
    match /coupons/{couponId} {
        // Anyone can read coupons to validate them
        allow read: if true;
        // Admin has full write access
        allow create, delete: if isAdmin();
        // Admin can update anything, users can only increment usedCount
        allow update: if isAdmin() || 
          (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']));
    }
    
    // Email Campaigns collection
    match /email_campaigns/{campaignId} {
        // Admin can read/write campaigns
        allow read, write: if isAdmin();
        
        // Allow public write to opens subcollection (for tracking pixel)
        match /opens/{openId} {
            allow read: if isAdmin();
            allow write: if true;
        }
        
        // Allow public write to clicks subcollection (for link tracking)
        match /clicks/{clickId} {
            allow read: if isAdmin();
            allow write: if true;
        }
    }

    // Notifications collection (for notification center)
    match /notifications/{notificationId} {
        // Allow all operations for authenticated users
        allow read, update, delete: if request.auth != null;
        // Allow create for server (API creates notifications)
        allow create: if true;
    }

    // Newsletter subscribers
    match /newsletter_subscribers/{subscriberId} {
        // Allow read for duplicate checking and admin management
        allow read: if true;
        // Anyone can subscribe (create)
        allow create: if true;
        // Allow update for unsubscribe (public)
        allow update: if true;
    }

    // Conversations (Chat Support)
    match /conversations/{conversationId} {
        // User can read/write their own conversations
        allow read, write: if request.auth != null && 
            (resource == null || resource.data.userId == request.auth.uid);
        // Admin has full access
        allow read, write: if isAdmin();
        
        // Messages subcollection
        match /messages/{messageId} {
            // User can read their conversation messages
            allow read: if request.auth != null && 
                get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid;
            // User can create messages in their conversation
            allow create: if request.auth != null;
            // Admin has full access
            allow read, write: if isAdmin();
        }
    }
  }
}

